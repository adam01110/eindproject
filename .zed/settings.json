{
	"lsp_document_colors": "background",
	"minimap": {
		"current_line_highlight": "line",
		"show": "always",
		"thumb_border": "none"
	},
	"scrollbar": {
		"axes": {
			"vertical": false
		}
	},
	"show_edit_predictions": false,
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"auto_install_extensions": {
		"biome": true,
		"color-highlight": true,
		"git-firefly": true,
		"html": true,
		"nix": true,
		"oxc": true,
		"tailwindcss": true,
		"tombi": true,
		"toml": true
	},
	"inlay_hints": {
		"enabled": true
	},
	"languages": {
		"CSS": {
			"formatter": {
				"external": {
					"command": "biome",
					"arguments": ["format", "--stdin-file-path", "{buffer_path}"]
				}
			},
			"language_servers": [
				"vscode-css-language-server",
				"tailwindcss-language-server",
				"!biome"
			]
		},
		"TypeScript": {
			"formatter": {
				"language_server": {
					"name": "oxc"
				}
			},
			"prettier": {
				"allowed": false
			}
		},
		"JSON": {
			"formatter": {
				"language_server": {
					"name": "oxc"
				}
			}
		},
		"Python": {
			"language_servers": ["ty", "!basedpyright", "..."],
			"formatter": {
				"code_actions": {
					"source.fixAll.ruff": true,
					"source.organizeImports.ruff": true
				}
			}
		},
		"Nix": {
			"formatter": {
				"external": {
					"command": "alejandra"
				}
			},
			"language_servers": ["nixd"]
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"inline_config": {
					"css": {
						"parser": {
							"tailwindDirectives": true
						}
					}
				}
			}
		},
		"tailwindcss-language-server": {
			"settings": {
				"experimental": {
					"classRegex": [
						"\\.className\\s*[+]?=\\s*['\"]([^'\"]*)['\"]",
						"\\.setAttributeNS\\(.*,\\s*['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
						"\\.setAttribute\\(['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
						"\\.classList\\.add\\(['\"]([^'\"]*)['\"]",
						"\\.classList\\.remove\\(['\"]([^'\"]*)['\"]",
						"\\.classList\\.toggle\\(['\"]([^'\"]*)['\"]",
						"\\.classList\\.contains\\(['\"]([^'\"]*)['\"]",
						"\\.classList\\.replace\\(\\s*['\"]([^'\"]*)['\"]",
						"\\.classList\\.replace\\([^,)]+,\\s*['\"]([^'\"]*)['\"]"
					]
				}
			}
		},
		"vscode-css-language-server": {
			"settings": {
				"css": {
					"lint": {
						"unknownAtRules": "ignore"
					}
				}
			}
		}
	}
}
